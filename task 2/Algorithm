def shell_ciura(a):
    n = len(a)
    span = n//2
    while span > 0:
        for i in range(span, n):
            number_a = a[i]
            number_b = i
            while number_b >= span and a[number_b-span] > number_a:
                a[number_b] = a[number_b-span]
                number_b = number_b - span
            a[number_b] = number_a
        span = span//2

number_input = input("Enter numbers that you want to sort(PLease separate them by ,):")
arr = [int(x) for x in number_input.split(",")]
shell_ciura(arr)
print(arr)