def shell_ciura(a):
    n = len(a)
    gap = n//2
    while gap > 0:
        for i in range(gap, n):
            number_a = a[i]
            number_b = i
            while number_b >= gap and a[number_b-gap] > number_a:
                a[number_b] = a[number_b-gap]
                number_b = number_b - gap
            a[number_b] = number_a
        gap = gap//2

number_input = input("Enter numbers that you want to sort(PLease separate them by ,):")
arr = [int(x) for x in number_input.split(",")]
shell_ciura(arr)
print(arr)